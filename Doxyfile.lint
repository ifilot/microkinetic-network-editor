# --- INPUT ---
INPUT                  = src
RECURSIVE              = YES

# --- OUTPUT (IMPORTANT: must enable one) ---
GENERATE_HTML          = YES
GENERATE_LATEX         = NO

# --- EXTRACTION ---
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES

# --- WARNINGS ---
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

# --- LOGGING ---
QUIET                  = NO
WARN_LOGFILE           = warnings.log